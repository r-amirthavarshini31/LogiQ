# LogiQ Environment Configuration
# Copy this file and fill in your values

# OpenAI API Key (optional — fallback mode works without it)
OPENAI_API_KEY=

# Ollama Endpoint (optional — local LLM alternative)
OLLAMA_ENDPOINT=http://localhost:11434

# Slack Webhook URL (optional)
SLACK_WEBHOOK_URL=

# Discord Webhook URL (optional)
DISCORD_WEBHOOK_URL=

# GitHub Integration (optional)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Flask
FLASK_SECRET_KEY=logiq-secret-key-change-me
